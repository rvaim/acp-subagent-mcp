{
  "mcpServers": {
    "acp-subagent": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@rvaim/acp-subagent-mcp"
      ],
      "env": {
        "ACP_SUBAGENT_DEFAULT_AGENT": "claude",
        "ACP_SUBAGENT_ENV_POLICY": "all",
        "ACP_SUBAGENT_SKILL_MODE": "list"
      }
    }
  }
}
