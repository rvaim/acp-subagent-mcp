{
  "name": "@rvaim/acp-subagent-mcp",
  "version": "0.1.11",
  "description": "通用 ACP 子代理 MCP Server",
  "type": "module",
  "bin": {
    "acp-subagent-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test:fake-agent": "SUBAGENT_MCP_CONFIG=examples/agents.toml node dist/index.js",
    "test:cancel-heartbeat": "npm run build && node tests/cancellation-and-heartbeat.mjs",
    "test:regression": "npm run build && node tests/default-heartbeat-allows-delayed-tool.mjs && node tests/cancellation-and-heartbeat.mjs && node tests/session-pool-reuse.mjs && node tests/default-permissions-allow-write.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "smol-toml": "^1.4.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "doc/",
    "examples/",
    "README.md"
  ]
}
